# Salin file ini menjadi .env dan isi dengan nilai yang sebenarnya
# File .env TIDAK boleh di-commit ke GitHub!

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Admin credentials
ADMIN_EMAIL=admin@himaprodi.com
ADMIN_PASSWORD=GantiDenganPasswordKuatMinimal12Karakter

# CORS - URL frontend yang diizinkan (pisahkan dengan koma jika lebih dari satu)
FRONTEND_URL=https://nama-web.vercel.app

# JWT Secret - gunakan string acak minimal 32 karakter
JWT_SECRET=GantiDenganStringAcakYangPanjangDanUnik
